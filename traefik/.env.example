# ── Domain ────────────────────────────────────────────────────────────────────
# Base domain for all services (e.g. traefik.tailnet.softwarekitchen.de)
DOMAIN=tailnet01.softwarekitchen.de

# ── GoDaddy DNS provider (for Let's Encrypt DNS-01 wildcard cert) ─────────────
# Get API keys at: https://developer.godaddy.com/keys
GODADDY_API_KEY=your_key_here
GODADDY_API_SECRET=your_secret_here

# ── netcup alternative ────────────────────────────────────────────────────────
# Comment out the GoDaddy vars above and fill these in if using netcup.
# Also change provider: to "netcup" in traefik.yml.
# NETCUP_CUSTOMER_NUMBER=your_customer_number
# NETCUP_API_KEY=your_api_key
# NETCUP_API_PASSWORD=your_api_password

# ── Traefik dashboard auth ────────────────────────────────────────────────────
# Generate htpasswd value with (requires apache2-utils):
#   echo $(htpasswd -nb admin yourpassword) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$changeme$$changeme
