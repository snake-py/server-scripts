# ── Domain (must match traefik .env) ──────────────────────────────────────────
DOMAIN=tailnet01.softwarekitchen.de

# ── External SMTP relay ────────────────────────────────────────────────────────
# Brevo (recommended — 300 emails/day free, no credit card)
#   Sign up at: https://app.brevo.com → SMTP & API → SMTP
RELAY_HOST=smtp-relay.brevo.com
RELAY_PORT=587
RELAY_USERNAME=your_brevo_login_email
RELAY_PASSWORD=your_brevo_smtp_password
RELAY_FROM=no-reply@softwarekitchen.de

# Mailgun alternative:
# RELAY_HOST=smtp.mailgun.org
# RELAY_PORT=587
# RELAY_USERNAME=postmaster@mg.softwarekitchen.de
# RELAY_PASSWORD=your_mailgun_password
# RELAY_FROM=no-reply@softwarekitchen.de

# Gmail alternative (less recommended — strict limits, requires App Password):
# RELAY_HOST=smtp.gmail.com
# RELAY_PORT=587
# RELAY_USERNAME=your@gmail.com
# RELAY_PASSWORD=your_gmail_app_password
# RELAY_FROM=your@gmail.com
